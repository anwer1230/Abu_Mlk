# ══════════════════════════════════════════════════════
#  متغيرات البيئة — مركز سرعة انجاز للخدمات
#  أضف هذه المتغيرات في لوحة Render > Environment
# ══════════════════════════════════════════════════════

# منفذ التشغيل (يُعيَّن تلقائياً من Render - لا تغيّره)
PORT=10000

# وضع Render (اتركه true عند النشر)
RENDER=true

# مفتاح الجلسة الأمني — غيّره لقيمة عشوائية طويلة
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_HERE

# مفتاح Groq AI — احصل عليه من console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# إعدادات GitHub (لحفظ الجلسات في المستودع)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=anwer1230/-Anwer_program
GITHUB_BRANCH=main
